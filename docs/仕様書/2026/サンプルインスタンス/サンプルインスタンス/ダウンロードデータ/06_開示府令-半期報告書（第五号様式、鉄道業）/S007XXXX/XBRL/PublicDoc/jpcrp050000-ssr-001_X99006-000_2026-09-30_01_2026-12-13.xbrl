&lt;/colgroup&gt;
&lt;tbody&gt;
&lt;tr style="height: 30.0pt; min-height: 30.0pt"&gt;
&lt;td style="border-top: solid black 0.75pt; border-left:  none; border-bottom: solid black 0.75pt; border-right: none; padding: 0pt"&gt;
&lt;p style="text-align: center; line-height: 10.0pt"&gt;
  &lt;/p&gt;
&lt;/td&gt;
&lt;td style="border-top: solid black 0.75pt; border-left:  none; border-bottom: solid black 0.75pt; border-right: none; padding: 0pt"&gt;
&lt;p style="text-align: center; line-height: 10.0pt"&gt;
前連結会計年度&lt;/p&gt;
&lt;p style="text-align: center; line-height: 10.0pt"&gt;
（令和８年３月31日）&lt;/p&gt;
&lt;/td&gt;
&lt;td style="border-top: solid black 0.75pt; border-left:  none; border-bottom: solid black 0.75pt; border-right: none; padding: 0pt"&gt;
&lt;p style="text-align: center; line-height: 10.0pt"&gt;
