<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase
    xmlns:link="http://www.xbrl.org/2003/linkbase"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd">

  <!-- Consolidated BS -->
  <link:presentationLink xlink:type="extended"
      xlink:role="http://disclosure.edinet-fsa.go.jp/role/jppfs/rol_std_ConsolidatedBalanceSheet">

    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetHeading"
        xlink:label="loc_C_BSHeading"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetTable"
        xlink:label="loc_C_BSTable"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetLineItems"
        xlink:label="loc_C_BSLineItems"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_TotalAssets"
        xlink:label="loc_C_TotalAssets"/>

    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_C_BSHeading" xlink:to="loc_C_BSTable" order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_C_BSTable" xlink:to="loc_C_BSLineItems" order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_C_BSLineItems" xlink:to="loc_C_TotalAssets" order="1"
        preferredLabel="http://www.xbrl.org/2003/role/totalLabel"/>
  </link:presentationLink>

  <!-- Non-consolidated BS -->
  <link:presentationLink xlink:type="extended"
      xlink:role="http://disclosure.edinet-fsa.go.jp/role/jppfs/rol_std_BalanceSheet">

    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetHeading"
        xlink:label="loc_N_BSHeading"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetTable"
        xlink:label="loc_N_BSTable"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_BalanceSheetLineItems"
        xlink:label="loc_N_BSLineItems"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_CashAndDeposits"
        xlink:label="loc_N_CashAndDeposits"/>

    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_N_BSHeading" xlink:to="loc_N_BSTable" order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_N_BSTable" xlink:to="loc_N_BSLineItems" order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_N_BSLineItems" xlink:to="loc_N_CashAndDeposits" order="1"/>
  </link:presentationLink>
</link:linkbase>
