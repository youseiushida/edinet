<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase
    xmlns:link="http://www.xbrl.org/2003/linkbase"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd">

  <link:presentationLink xlink:type="extended"
      xlink:role="http://disclosure.edinet-fsa.go.jp/role/jppfs/rol_std_ConsolidatedStatementOfIncome">

    <!-- Main PL: operating income section -->
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_StatementOfIncomeHeading"
        xlink:label="loc_PLHeading"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_StatementOfIncomeTable"
        xlink:label="loc_PLTable"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_StatementOfIncomeLineItems"
        xlink:label="loc_PLLineItems"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_OperatingIncomeAbstract"
        xlink:label="loc_OperatingIncomeAbstract"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_OperatingIncome"
        xlink:label="loc_OperatingIncome"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_OrdinaryIncome"
        xlink:label="loc_OrdinaryIncome"/>
    <link:loc xlink:type="locator"
        xlink:href="jppfs_cor.xsd#jppfs_cor_NetIncome"
        xlink:label="loc_NetIncome"/>

    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_PLHeading" xlink:to="loc_PLTable"
        order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_PLTable" xlink:to="loc_PLLineItems"
        order="1"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_PLLineItems" xlink:to="loc_OperatingIncomeAbstract"
        order="5"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_OperatingIncomeAbstract" xlink:to="loc_OperatingIncome"
        order="1"
        preferredLabel="http://www.xbrl.org/2003/role/totalLabel"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_PLLineItems" xlink:to="loc_OrdinaryIncome"
        order="6"
        preferredLabel="http://www.xbrl.org/2003/role/totalLabel"/>
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_PLLineItems" xlink:to="loc_NetIncome"
        order="7"
        preferredLabel="http://www.xbrl.org/2003/role/totalLabel"/>

  </link:presentationLink>
</link:linkbase>
