<?xml version="1.0" encoding="UTF-8"?>
<link:linkbase
    xmlns:link="http://www.xbrl.org/2003/linkbase"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.xbrl.org/2003/linkbase http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd">

  <link:presentationLink xlink:type="extended"
      xlink:role="http://disclosure.edinet-fsa.go.jp/role/jppfs/rol_BalanceSheet">

    <!-- 正常な loc -->
    <link:loc xlink:type="locator"
        xlink:href="../taxonomy/jppfs/2025-11-01/jppfs_cor_2025-11-01.xsd#jppfs_cor_BalanceSheetHeading"
        xlink:label="loc_BSHeading"/>
    <link:loc xlink:type="locator"
        xlink:href="../taxonomy/jppfs/2025-11-01/jppfs_cor_2025-11-01.xsd#jppfs_cor_TotalAssets"
        xlink:label="loc_TotalAssets"/>
    <link:loc xlink:type="locator"
        xlink:href="../taxonomy/jppfs/2025-11-01/jppfs_cor_2025-11-01.xsd#jppfs_cor_CashAndDeposits"
        xlink:label="loc_Cash"/>
    <link:loc xlink:type="locator"
        xlink:href="../taxonomy/jppfs/2025-11-01/jppfs_cor_2025-11-01.xsd#jppfs_cor_Inventories"
        xlink:label="loc_Inventories"/>

    <!-- href 欠落の loc -->
    <link:loc xlink:type="locator"
        xlink:label="loc_NoHref"/>

    <!-- 正常な arc -->
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_BSHeading" xlink:to="loc_TotalAssets"
        order="1"/>

    <!-- order 欠落の arc（デフォルト 0.0 にフォールバック） -->
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_BSHeading" xlink:to="loc_Cash"/>

    <!-- 非数値 order の arc（0.0 にフォールバック） -->
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_BSHeading" xlink:to="loc_Inventories"
        order="abc"/>

    <!-- href 欠落 loc を参照する arc（loc が無効なのでスキップされる） -->
    <link:presentationArc xlink:type="arc"
        xlink:arcrole="http://www.xbrl.org/2003/arcrole/parent-child"
        xlink:from="loc_BSHeading" xlink:to="loc_NoHref"
        order="5"/>

  </link:presentationLink>
</link:linkbase>
